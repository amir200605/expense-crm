# Database (PostgreSQL — required)
# Local: create a DB and paste your connection string.
# Replit: add the built-in PostgreSQL database from the Database tool; Replit usually injects
# DATABASE_URL automatically (also check Tools → Secrets). Then run: npx prisma migrate deploy
# If SSL errors: append ?sslmode=require (or use the exact URL Replit shows for the database).
DATABASE_URL="postgresql://user:password@localhost:5432/expenseflow_crm?schema=public"

# NextAuth
NEXTAUTH_SECRET="generate-a-random-secret-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# Telnyx SMS (server-only; not stored in app DB)
# Use .env.local for secrets (gitignored). Restart `npm run dev` after editing.
# On Replit: Tools → Secrets — same names.
# TELNYX_API_KEY=key_xxxxxxxxxxxxxxxxxxxxxxxx
# Optional: sending number if not saved in Settings → Integrations (E.164, e.g. +15551234567)
# TELNYX_FROM_NUMBER=
# Optional: only if Telnyx requires an explicit profile UUID (your `from` number must still be on this profile)
# TELNYX_MESSAGING_PROFILE_ID=

# Outlook / SMTP (optional — overrides Settings → Integrations when set)
# OUTLOOK_FROM_EMAIL=noreply@yourdomain.com
# OUTLOOK_SMTP_USER=noreply@yourdomain.com
# OUTLOOK_SMTP_PASSWORD=your-app-password

# Optional: SMS (Twilio) — legacy
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=

# Optional: Email (Resend)
# RESEND_API_KEY=

# Optional: Redis for queues
# REDIS_URL=

# App URL (for links in emails)
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# IANA timezone for all displayed dates/times (server + browser must agree — avoids React hydration errors)
# NEXT_PUBLIC_APP_TIMEZONE=America/New_York

# OpenAI (for AI assistant)
OPENAI_API_KEY=sk-your-openai-api-key-here
