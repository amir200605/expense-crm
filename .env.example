# Database
DATABASE_URL="postgresql://user:password@localhost:5432/expenseflow_crm?schema=public"

# NextAuth
NEXTAUTH_SECRET="generate-a-random-secret-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# Telnyx SMS (server-only; not stored in app DB)
TELNYX_API_KEY=
# Optional: only if Telnyx requires an explicit profile UUID (your `from` number must still be on this profile)
# TELNYX_MESSAGING_PROFILE_ID=

# Optional: SMS (Twilio) — legacy
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=

# Optional: Email (Resend)
# RESEND_API_KEY=

# Optional: Redis for queues
# REDIS_URL=

# App URL (for links in emails)
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# IANA timezone for all displayed dates/times (server + browser must agree — avoids React hydration errors)
# NEXT_PUBLIC_APP_TIMEZONE=America/New_York

# OpenAI (for AI assistant)
OPENAI_API_KEY=sk-your-openai-api-key-here
